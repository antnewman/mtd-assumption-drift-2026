# Supabase project credentials for the pda-investigations project.
# Read the service role key from the Supabase dashboard at:
#   https://supabase.com/dashboard/project/bulheatuxvktopxrwbvs
# under Settings > API. Do not commit this value. Rotate the key after
# any accidental exposure (Settings > API > regenerate JWT secret).
SUPABASE_URL=https://bulheatuxvktopxrwbvs.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# PDA Platform endpoint for fetching external signals.
# Leave blank to use a local in-process install of pda-platform, which
# is the default and is preferred for reproducibility. Set to the
# hosted MCP endpoint if running against Render instead:
#   PDA_PLATFORM_ENDPOINT=https://pda-platform-i33p.onrender.com/sse
PDA_PLATFORM_ENDPOINT=
